			assertHex(t, tc.name, got[:], tc.want)
		})
	}
}

func TestPacketCommitmentPath(t *testing.T) {
	tests := []struct {
		name    string
		packet  Packet
		want    string
		wantErr bool
	}{
		{
			name: "basic packet",
			packet: Packet{
				SourceChannelId:      1,
				DestinationChannelId: 2,
				Data:                 []byte{0xab, 0xcd},
				TimeoutHeight:        0,
				TimeoutTimestamp:     3,
			},
			want:    "dfac6be4ea8189f2107780fd50b6532901f7692506a56c45e224a15d64eb040c",
			wantErr: false,
		},
		{
			name: "packet with empty data",
			packet: Packet{
				SourceChannelId:      0,
				DestinationChannelId: 1,
				Data:                 []byte{},
				TimeoutHeight:        0,
				TimeoutTimestamp:     100,
			},
			want:    "d56102fe70b54c587934a3e35d3c40b458da7fb1fd48ef655b38e1ec99fda460",
			wantErr: false,
		},
	}

	for _, tc := range tests {
		t.Run(tc.name, func(t *testing.T) {
			got, err := PacketCommitmentPath(tc.packet)
			if tc.wantErr {
				if err == nil {
					t.Fatal("expected error, got nil")
				}
				return
			}
			if err != nil {
				t.Fatalf("unexpected error: %v", err)
			}
			assertHex(t, tc.name, got[:], tc.want)
		})
	}
}

func TestPacketAcknowledgementPath(t *testing.T) {
	tests := []struct {
		name    string
		packet  Packet
		want    string
		wantErr bool
	}{
		{
			name: "basic packet",
			packet: Packet{
				SourceChannelId:      1,
				DestinationChannelId: 2,
				Data:                 []byte{0xab, 0xcd},
				TimeoutHeight:        0,
				TimeoutTimestamp:     3,
			},
			want:    "af591cb9e48aa20a528e75d0a6eea3caa16e49e3fef9e16781e5284f659ddf80",
			wantErr: false,
		},
		{
			name: "packet with empty data",
			packet: Packet{
				SourceChannelId:      0,
				DestinationChannelId: 1,
				Data:                 []byte{},
				TimeoutHeight:        0,
				TimeoutTimestamp:     100,
			},
			want:    "74dd41d176f27cca1cbd07107e2042d3f3b2e91076ae2e66afa382c39ce80f0a",
			wantErr: false,
		},
	}

	for _, tc := range tests {
		t.Run(tc.name, func(t *testing.T) {
			got, err := PacketAcknowledgementPath(tc.packet)
			if tc.wantErr {
				if err == nil {
					t.Fatal("expected error, got nil")
