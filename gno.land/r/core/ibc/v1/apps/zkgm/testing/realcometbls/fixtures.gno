	DevnetTimeNanos   = int32(998131342)

	longTrustingPeriod = uint64(100 * 365 * 24 * 3600 * 1_000_000_000)
)

// The synthetic*, z35*, z36*, z37*, z39*, and z40* byte literals below are generated by
// tools/cometbls-fixtures against a shared IAVL subtree. Regenerate via
// `cd tools/cometbls-fixtures && go run .` and keep these in sync:
//   - gno.land/p/core/ibc/lightclients/cometbls/synthetic_fixture_test.gno
//     mirrors the synthetic* proofs and roots.
//   - scenarios/z35_fixture_inputs_filetest.gno and
//     gno.land/r/core/ibc/v1/core/z35_fixture_inputs_test.gno derive the
//     z35*Key/z35*Value bytes from the production path/encoding code, so
//     drift in either direction breaks one of those checks first.
//   - scenarios/packet_lifecycle_fixture_inputs_filetest.gno and
//     gno.land/r/core/ibc/v1/core/packet_lifecycle_fixture_inputs_test.gno derive the
//     z36/z37 key/value bytes from the production path/encoding code.
//   - scenarios/z39_fixture_inputs_filetest.gno and
//     gno.land/r/core/ibc/v1/core/z39_fixture_inputs_test.gno derive the
