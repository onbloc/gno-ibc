// PKGPATH: gno.land/r/aib/main
package main

// recv_ack_ok_filetest is the control case for
// recv_forward_ack_pending_filetest.gno: Receiver is an ordinary address,
// not ZKGM's proxy address, so tryForward's discriminator doesn't match even
// though the memo is still forward-shaped (proving memo shape alone never
// triggers forwarding). OnRecvPacket mints straight to Receiver and acks
// immediately - no ZKGM involvement, no deferred ack.

import (
	"encoding/hex"
	"time"

	tmtesting "gno.land/p/aib/ibc/lightclient/tendermint/testing"
	"gno.land/p/aib/ibc/types"
	"gno.land/p/aib/ics23"
	"gno.land/p/nt/testutils/v0"
	"gno.land/p/nt/ufmt/v0"
	"gno.land/r/aib/ibc/apps/transfer"
	"gno.land/r/aib/ibc/core"
)

const timeoutTimestamp = uint64(1234571490)

func main(cur realm) {
	var (
		chainID        = "chainA-2"
		trustedHeight  = types.NewHeight(2, 2)
		clientState    = tmtesting.NewClientState(chainID, trustedHeight)
		apphash, _     = hex.DecodeString("d55b55907b2b7bbcc7fd2732adfd1b43b42b270d4c745821c2ff3ef1621774f3")
		trustedValset  = tmtesting.GenValset()
		consensusState = tmtesting.GenConsensusState(time.Now(), apphash, trustedValset.Hash())
		counterpartyID = "07-tendermint-42"
	)
	clientID := core.CreateClient(cross(cur), clientState, consensusState)
	core.RegisterCounterparty(cross(cur), clientID, [][]byte{[]byte("iavlStoreKey"), []byte("prefix2")}, counterpartyID)

	println("[INFO] atomone client:", clientID)

	// Same forward-shaped memo as recv_forward_ack_pending_filetest.gno, but
	// Receiver is a plain address instead of zkgm's proxy address.
	receiver := testutils.TestAddress("receiver")
	memo := `{"forward":{"channel":1,"receiver":"0xaabbccdd","quote_token":"0x11223344","metadata":{"implementation":"0x01","initializer":"0x02"}}}`
	payload := transfer.NewFungibleTokenPacketData("uatone", "100", "atone1sender", receiver.String(), memo)
	payloadBz := payload.ProtoMarshal()

	println("[INFO] payload proto hex:", hex.EncodeToString(payloadBz))

	voucherDenom := transfer.NewDenom("uatone", transfer.NewHop(transfer.PortID, clientID)).IBCDenom()
	ufmt.Printf("[INFO] receiver voucher balance before recv: %d\n", transfer.VoucherBalanceOf(voucherDenom, receiver))
	ufmt.Println("[EXPECTED] should be 0 (voucher doesn't exist yet)")

	specs := ics23.IavlSpec()
	recvPacket := types.MsgRecvPacket{
		Packet: types.Packet{
			Sequence:          1,
			SourceClient:      counterpartyID,
			DestinationClient: clientID,
			TimeoutTimestamp:  timeoutTimestamp,
			Payloads: []types.Payload{{
				SourcePort:      transfer.PortID,
				DestinationPort: transfer.PortID,
				Encoding:        transfer.EncodingProtobuf,
				Value:           payloadBz,
				Version:         transfer.V1,
			}},
		},
		// NOTE proof generated by:
		// go run -C ./cmd/gen-proof . 'prefix2' '07-tendermint-42' 'packet' '{"sequence":1,"source_client":"07-tendermint-42","destination_client":"07-tendermint-1","timeout_timestamp":1234571490,"payloads":[{"source_port":"transfer","destination_port":"transfer","encoding":"application/x-protobuf","value":"CgZ1YXRvbmUSAzEwMBoMYXRvbmUxc2VuZGVyIihnMXdmamt4ZXRmd2VqaHloNmx0YTA0N2g2bHRhMDQ3aDZsbG04MnlsKoYBeyJmb3J3YXJkIjp7ImNoYW5uZWwiOjEsInJlY2VpdmVyIjoiMHhhYWJiY2NkZCIsInF1b3RlX3Rva2VuIjoiMHgxMTIyMzM0NCIsIm1ldGFkYXRhIjp7ImltcGxlbWVudGF0aW9uIjoiMHgwMSIsImluaXRpYWxpemVyIjoiMHgwMiJ9fX0=","version":"ics20-1"}]}'
		ProofCommitment: []ics23.CommitmentProof{
			// iavl proof
			ics23.CommitmentProof_Exist{
				Exist: &ics23.ExistenceProof{
					Key:   []byte("\x70\x72\x65\x66\x69\x78\x32\x30\x37\x2d\x74\x65\x6e\x64\x65\x72\x6d\x69\x6e\x74\x2d\x34\x32\x01\x00\x00\x00\x00\x00\x00\x00\x01"),
					Value: []byte("\x41\x30\x58\xcf\x55\xa3\x56\x72\xa1\x01\x8d\x75\xd2\xa1\x92\xe9\x6e\xfe\x0f\x54\xa9\xc6\x1f\xd8\xc2\x62\x6e\x07\x2a\xac\x18\xaf"),
					Leaf: &ics23.LeafOp{
						Hash:         specs.LeafSpec.Hash,
						PrehashKey:   specs.LeafSpec.PrehashKey,
						PrehashValue: specs.LeafSpec.PrehashValue,
						Length:       specs.LeafSpec.Length,
						Prefix:       []byte("\x00\x02\x02"),
					},
					Path: []*ics23.InnerOp{
						{
							Hash:   specs.InnerSpec.Hash,
							Prefix: []byte("\x02\x04\x02\x20\x35\xf8\xea\x80\x53\x90\xe0\x84\x85\x4f\x39\x9b\x42\xcc\xde\xae\xa3\x3a\x1d\xed\xc1\x15\x63\x8a\xc4\x8d\x06\x00\x63\x7d\xba\x1f\x20"),
							Suffix: []byte(""),
						},
						{
							Hash:   specs.InnerSpec.Hash,
							Prefix: []byte("\x04\x08\x02\x20"),
							Suffix: []byte("\x20\x79\x8e\x2c\xaa\x96\xfd\xfb\xa3\x76\xdd\xeb\x47\x99\x99\x54\xd2\xf4\x7e\x65\x16\x22\x64\xb0\x53\x6a\xb5\xdf\xf7\xfc\x0a\x2e\x07"),
						},
						{
							Hash:   specs.InnerSpec.Hash,
							Prefix: []byte("\x06\x0c\x02\x20\x9a\xf3\x7d\xd5\x95\xa0\x19\x08\x03\xb5\xe0\x5a\xae\xf4\x2a\xe3\xfa\xd4\x99\xe4\xfb\xe3\x7f\x7c\xd3\x1c\xad\xff\x22\xa9\xee\x74\x20"),
							Suffix: []byte(""),
						},
					},
				},
			},
			// rootmulti proof
			ics23.CommitmentProof_Exist{
				Exist: &ics23.ExistenceProof{
					Key:   []byte("\x69\x61\x76\x6c\x53\x74\x6f\x72\x65\x4b\x65\x79"),
					Value: []byte("\xe0\xaf\x80\x3d\x81\x98\x93\x27\x4b\xcd\x82\x99\xd4\xef\x80\xfe\xbe\x8e\x43\x91\x31\x4b\x43\xf3\x6c\x43\x4d\xf6\x50\xec\xfe\x88"),
					Leaf: &ics23.LeafOp{
						Hash:         specs.LeafSpec.Hash,
						PrehashKey:   specs.LeafSpec.PrehashKey,
						PrehashValue: specs.LeafSpec.PrehashValue,
						Length:       specs.LeafSpec.Length,
						Prefix:       []byte("\x00"),
					},
					Path: []*ics23.InnerOp{},
				},
			},
		},
		ProofHeight: trustedHeight,
	}
	recvRes := core.RecvPacket(cross(cur), recvPacket)
	if recvRes != types.RESPONSE_SUCCESS {
		panic("expected recv success")
	}
	println("[INFO] recv res:", recvRes)

	ufmt.Printf("[INFO] receiver voucher balance after recv: %d\n", transfer.VoucherBalanceOf(voucherDenom, receiver))
	ufmt.Println("[EXPECTED] should be 100 (minted straight to Receiver - no forward)")

	// Unlike the forward case, this ack is written immediately (sync), not
	// deferred.
	println("[INFO] atomone packet ack (should NOT be pending):", core.Render("clients/"+clientID+"/packet_acknowledgements/1"))
}

// Output:
// [INFO] atomone client: 07-tendermint-1
// [INFO] payload proto hex: 
// [INFO] receiver voucher balance before recv: 0
// [EXPECTED] should be 0 (voucher doesn't exist yet)
// [INFO] recv res: (2 gno.land/p/aib/ibc/types.ResponseResultType)
// [INFO] receiver voucher balance after recv: 100
// [EXPECTED] should be 100 (minted straight to Receiver - no forward)
// [INFO] atomone packet ack (should NOT be pending): {"sequence":"1","data":"hGDiH3O1PXeeSzKRzTUzjpL66ZmHNfGgtxUMB0wHMaY="}
