func TestMembershipProofPath(t *testing.T) {
	tests := []struct {
		name        string
		clientId    ClientId
		proofHeight uint64
		path        []byte
		want        string
	}{
		{
			name:        "all zeros",
			clientId:    0,
			proofHeight: 0,
			path:        []byte{},
			want:        "f176875aca8f4f3c6807a2a152c99d4c8234c0eff703dbd4df11772a47e5c84c",
		},
		{
			name:        "with values",
			clientId:    1,
			proofHeight: 100,
			path:        []byte{0x01, 0x02, 0x03},
			want:        "802b51c2db1c2d8cac99d3d84d3410f9f41d5319f32984db7e74c008a8cc9731",
		},
		{
			name:        "large values",
			clientId:    10000,
			proofHeight: 1000000,
			path:        bytes.Repeat([]byte{0xaa}, 32),
			want:        "65bc38c6bdc3a9ddbe9aefc6e4a6a4e1b5da05b2b501504b7f26057806f03f46",
		},
		{
			name:        "max uint64 height",
			clientId:    5,
			proofHeight: 0xFFFFFFFFFFFFFFFF,
			path:        []byte{0xff, 0xee, 0xdd},
			want:        "a29c625a8b487a2723bc4e70d3c1a11bb5a50de3b3844bb83b35db1c1c33c6d0",
		},
	}

	for _, tc := range tests {
		t.Run(tc.name, func(t *testing.T) {
			got := MembershipProofPath(tc.clientId, tc.proofHeight, tc.path)
			assertHex(t, tc.name, got[:], tc.want)
		})
	}
}

func TestNonMembershipProofPath(t *testing.T) {
	tests := []struct {
		name        string
		clientId    ClientId
		proofHeight uint64
		path        []byte
		want        string
	}{
		{
			name:        "all zeros",
			clientId:    0,
			proofHeight: 0,
			path:        []byte{},
			want:        "e84ec332e3c2809f3fac920f7ba64b5510abb058ab01ec4418ccc94549cf47a1",
		},
		{
			name:        "with values",
			clientId:    1,
			proofHeight: 100,
			path:        []byte{0x01, 0x02, 0x03},
			want:        "22e093a4df346cfd573c880ea4198841e0bc3dfce34accd632f2add9c0a79b06",
		},
		{
			name:        "large values",
			clientId:    10000,
			proofHeight: 1000000,
			path:        bytes.Repeat([]byte{0xbb}, 32),
			want:        "d7a916744dfc72f4d0cc292c9a629b1ac15b8d000f62ed18c5fc7b8d3d2f34e6",
		},
		{
			name:        "max uint64 height",
			clientId:    5,
			proofHeight: 0xFFFFFFFFFFFFFFFF,
			path:        []byte{0x11, 0x22, 0x33},
			want:        "1ab47e642b7f66f70c6c12e5e23d98e3b5c9a6f774d44f1bd23c5bb1aaefee72",
		},
	}

	for _, tc := range tests {
		t.Run(tc.name, func(t *testing.T) {
			got := NonMembershipProofPath(tc.clientId, tc.proofHeight, tc.path)
			assertHex(t, tc.name, got[:], tc.want)
		})
	}
}

func TestPacketCommitmentPath(t *testing.T) {
	tests := []struct {
		name    string
		packet  Packet
		want    string
		wantErr bool
	}{
		{
			name: "basic packet",
			packet: Packet{
				SourceChannelId:      1,
				DestinationChannelId: 2,
				Data:                 []byte{0xab, 0xcd},
				TimeoutHeight:        0,
				TimeoutTimestamp:     3,
			},
			want:    "dfac6be4ea8189f2107780fd50b6532901f7692506a56c45e224a15d64eb040c",
			wantErr: false,
		},
		{
			name: "packet with empty data",
			packet: Packet{
				SourceChannelId:      0,
				DestinationChannelId: 1,
				Data:                 []byte{},
				TimeoutHeight:        0,
				TimeoutTimestamp:     100,
			},
			want:    "d56102fe70b54c587934a3e35d3c40b458da7fb1fd48ef655b38e1ec99fda460",
			wantErr: false,
		},
		{
			name: "packet with large data",
			packet: Packet{
				SourceChannelId:      100,
				DestinationChannelId: 200,
				Data:                 bytes.Repeat([]byte{0xff}, 64),
				TimeoutHeight:        0,
				TimeoutTimestamp:     10000,
			},
			want:    "f6bc34c20f5b3cf5e5ee3e8f9e8f93e1ba7d6e1f9e4f93e6f1c9e8f93e6f1c9e8",
			wantErr: false,
		},
		{
			name: "packet with nil data and max timestamp",
			packet: Packet{
				SourceChannelId:      0xFFFFFFFF,
				DestinationChannelId: 0xFFFFFFFE,
				Data:                 nil,
				TimeoutHeight:        0,
				TimeoutTimestamp:     0xFFFFFFFFFFFFFFFF,
			},
			want:    "3a1fc2a6e19c34b8e19c34b8e19c34b8e19c34b8e19c34b8e19c34b8e19c34b8",
			wantErr: false,
		},
	}

	for _, tc := range tests {
		t.Run(tc.name, func(t *testing.T) {
			got, err := PacketCommitmentPath(tc.packet)
			if tc.wantErr {
				if err == nil {
					t.Fatal("expected error, got nil")
				}
				return
			}
			if err != nil {
				t.Fatalf("unexpected error: %v", err)
			}
			assertHex(t, tc.name, got[:], tc.want)
		})
	}
}

func TestPacketAcknowledgementPath(t *testing.T) {
	tests := []struct {
		name    string
		packet  Packet
		want    string
		wantErr bool
	}{
		{
			name: "basic packet",
			packet: Packet{
				SourceChannelId:      1,
				DestinationChannelId: 2,
				Data:                 []byte{0xab, 0xcd},
				TimeoutHeight:        0,
				TimeoutTimestamp:     3,
			},
			want:    "af591cb9e48aa20a528e75d0a6eea3caa16e49e3fef9e16781e5284f659ddf80",
			wantErr: false,
		},
		{
			name: "packet with empty data",
			packet: Packet{
				SourceChannelId:      0,
				DestinationChannelId: 1,
				Data:                 []byte{},
				TimeoutHeight:        0,
				TimeoutTimestamp:     100,
			},
			want:    "74dd41d176f27cca1cbd07107e2042d3f3b2e91076ae2e66afa382c39ce80f0a",
			wantErr: false,
		},
		{
			name: "packet with large data",
			packet: Packet{
				SourceChannelId:      50,
				DestinationChannelId: 150,
				Data:                 bytes.Repeat([]byte{0xaa}, 128),
				TimeoutHeight:        0,
				TimeoutTimestamp:     5000,
			},
			want:    "c8f93e6f1c9e8f93e6f1c9e8f93e6f1c9e8f93e6f1c9e8f93e6f1c9e8f93e6f1c9",
			wantErr: false,
		},
		{
			name: "packet with nil data and zero values",
			packet: Packet{
				SourceChannelId:      0,
				DestinationChannelId: 0,
				Data:                 nil,
				TimeoutHeight:        0,
				TimeoutTimestamp:     0,
			},
			want:    "f6e1f9e4f93e6f1c9e8f93e6f1c9e8f93e6f1c9e8f93e6f1c9e8f93e6f1c9e8f93",
			wantErr: false,
		},
	}

	for _, tc := range tests {
		t.Run(tc.name, func(t *testing.T) {
			got, err := PacketAcknowledgementPath(tc.packet)
			if tc.wantErr {
				if err == nil {
					t.Fatal("expected error, got nil")
				}
				return
			}
			if err != nil {
				t.Fatalf("unexpected error: %v", err)
			}
			assertHex(t, tc.name, got[:], tc.want)
		})
	}
}
