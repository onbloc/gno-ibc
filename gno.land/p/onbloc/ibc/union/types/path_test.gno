			name:     "client zero height zero",
			clientId: 0,
			height:   NewHeight(0),
			want:     "255ace0592d6d0057743ec81f2494d71fe5466986a2fd6f28c632dc1ef83d48b",
		},
		{
			name:     "client one height one",
			clientId: 1,
			height:   NewHeight(1),
			want:     "525876128d9eb0ad1b9e0d64c9c51b1cd33790861c401ad2e3df0f670ce6a2a4",
