# Pinned gno toolchain.
#
# `make install-gno` clones the repo at the commit below and `go install`s
# the gno, gnoland, gnodev, and gnokey binaries from it. The IBC crypto
# stdlibs ship in the upstream toolchain (gnolang/gno#5725).
#
# Bump the commit to roll the upstream toolchain.

GNO_REPO=https://github.com/moul/gno.git
