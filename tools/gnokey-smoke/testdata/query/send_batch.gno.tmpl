package main

import (
	"gno.land/p/onbloc/ibc/union/types"
	"gno.land/r/onbloc/ibc/union/core"
	"gno.land/r/onbloc/ibc/union/apps/ucs03_zkgm/testing/e2e"
)

func main(cur realm) {
	packet := types.NewPacket(
		types.ChannelId(@MOCK_SOURCE@),
		types.ChannelId(@MOCK_DEST@),
		[]byte("hello"),
		types.Timestamp(1<<60),
	)
	batchHash := e2e.BatchSend(cross(cur), packet)
	println("batch_hash", batchHash.String())
}
