package types

import (
	"bytes"
	"testing"
)

// COMMITMENT_MAGIC, COMMITMENT_MAGIC_ACK and mergeAck are defined in path.gno.

func TestMergeAck(t *testing.T) {
	tests := []struct {
		name string
		ack  H256
		want string
	}{
		{
			name: "sets commitment magic byte",
			ack:  mustH256(t, "aa11111111111111111111111111111111111111111111111111111111111111"),
			want: "0111111111111111111111111111111111111111111111111111111111111111",
		},
		{
			name: "preserves existing magic byte",
			ack:  mustH256(t, "0122222222222222222222222222222222222222222222222222222222222222"),
			want: "0122222222222222222222222222222222222222222222222222222222222222",
		},
	}

	for _, tc := range tests {
		t.Run(tc.name, func(t *testing.T) {
			original := tc.ack
			got := mergeAck(tc.ack)
			assertHex(t, tc.name, got[:], tc.want)
			if tc.ack != original {
				t.Fatal("mergeAck mutated caller value")
			}
		})
	}
}

// Golden path constructor tests.
// Expected values are generated by running the functions and capturing their output.

func TestClientStatePath(t *testing.T) {
	tests := []struct {
		name     string
		clientId ClientId
		want     string
	}{
		{
			name:     "client zero",
			clientId: 0,
			want:     "ad3228b676f7d3cd4284a5443f17f1962b36e491b30a40b2405849e597ba5fb5",
		},
		{
			name:     "client one",
			clientId: 1,
			want:     "a6eef7e35abe7026729641147f7915573c7e97b47efa546f5f6e3230263bcb49",
		},
		{
			name:     "large client id",
			clientId: 1000000,
			want:     "c033441713512b1dc2fd4ba8568c2cfacae5f5e4debe33f523e43791183b2d38",
		},
		{
			name:     "max uint32 client id",
			clientId: 0xFFFFFFFF,
			want:     "aa7f6db4c3d761d3818cbb4cf949eb549bfe4caa062d07def734e6c03cc09fa7",
		},
	}

	for _, tc := range tests {
		t.Run(tc.name, func(t *testing.T) {
			got := ClientStatePath(tc.clientId)
			assertHex(t, tc.name, got[:], tc.want)
		})
	}
}

func TestConsensusStatePath(t *testing.T) {
	tests := []struct {
		name     string
		clientId ClientId
		height   Height
		want     string
	}{
		{
			name:     "client zero height zero",
			clientId: 0,
			height:   NewHeight(0),
			want:     "255ace0592d6d0057743ec81f2494d71fe5466986a2fd6f28c632dc1ef83d48b",
		},
		{
			name:     "client one height one",
			clientId: 1,
			height:   NewHeight(1),
			want:     "525876128d9eb0ad1b9e0d64c9c51b1cd33790861c401ad2e3df0f670ce6a2a4",
		},
		{
			name:     "large client id and height",
			clientId: 9999,
			height:   NewHeight(10000),
			want:     "2a9cc7bb20e26809f2761043d85e2cb269d471d999d8bfe97052b22e03c3e9b",
		},
		{
			name:     "max uint64 height",
			clientId: 1,
			height:   NewHeight(0xFFFFFFFFFFFFFFFF),
			want:     "e8c89c6d944e1dfc5e6cf60bc9ae82f8ed6867576b5df99b6f1b3cd4efbb1c72",
		},
	}

	for _, tc := range tests {
		t.Run(tc.name, func(t *testing.T) {
			got := ConsensusStatePath(tc.clientId, tc.height)
			assertHex(t, tc.name, got[:], tc.want)
		})
	}
}

