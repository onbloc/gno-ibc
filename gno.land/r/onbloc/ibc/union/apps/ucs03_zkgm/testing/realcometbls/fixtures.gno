}

func Z42StaleConsensusStateBytes(cur realm) []byte {
	return consensusStateBytes(z42StaleRoot, uint64(DevnetTimeSeconds-1000)*1_000_000_000)
}

func consensusStateBytes(root []byte, timestamp uint64) []byte {
	bz, err := cometblsp.EncodeConsensusState(&cometblsp.ConsensusState{
		Timestamp:          timestamp,
		NextValidatorsHash: h256Bytes(devnetValidatorsHash),
		Root: cometblsp.MerkleRoot{
			Hash: cloneBytes(root),
		},
	})
	if err != nil {
		panic(err)
	}
	return bz
}

