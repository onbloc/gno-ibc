			proofHex: "0adb010ad8010a2005f3c8eef62e74b10b7ee910fcc73c8358000f692d9ce2341a989e008e45" +
				"b35d1220ff4fb67348c16e70c898c7cf43c460a684bc900d2b41e5a24ef6dcb2945860341a0d" +
				"08011000180120012a030002022229080112250204022011ae5dd3dc5fa459cd485e01e6219d09" +
