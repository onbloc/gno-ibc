# Required live topology. Copy values from the confirmed Union EVM deployment.
UNION_CHAIN_ID=union-devnet-1
EVM_CHAIN_ID=
GNO_CHAIN_ID=dev.ibc

# Clean Voyager source checkout. The runner builds the pinned Nix Docker image.
UNION_VOYAGER_DIR=../../../union-voyager
UNION_VOYAGER_REVISION=9024777562dcaa01613017cd0b958569b85e243e
# Optional local image tag; it includes the pinned revision by default.
# VOYAGER_IMAGE=union-voyager-e2e:9024777562dc
# Optional explicit Linux flake system; it must match Docker's architecture.
# VOYAGER_NIX_SYSTEM=x86_64-linux

# Public deployed contracts/realms
UNION_IBC_HOST_CONTRACT=union1nk3nes4ef6vcjan5tz6stf9g8p08q2kgqysx6q5exxh89zakp0msq5z79t
EVM_IBC_HANDLER=
EVM_MULTICALL=
GNO_IBC_CORE_REALM=gno.land/r/onbloc/ibc/union/core
GNO_ZKGM_PORT=gno.land/r/onbloc/ibc/union/apps/ucs03_zkgm
EVM_ZKGM_CONTRACT=
GALOIS_PROVER_ENDPOINT=https://galois.union.build:443

# Optional --erc20-to-gno packet phase. Use a predeployed mint(address,uint256)
# test token; the amount is in 18-decimal units and must be divisible by 10^12.
EVM_TEST_ERC20=
GNO_RECIPIENT=
EVM_TEST_AMOUNT=1000000000000

# Required endpoints. Keep credentials in e2e/union/.env, never here.
UNION_RPC_URL=
EVM_RPC_URL=
GNO_RPC_URL=
GNO_TX_INDEXER_RPC_URL=
VOYAGER_DATABASE_URL=

# Required 0x-prefixed 32-byte raw private keys.
TRUSTED_MPT_PRIVATE_KEY=
UNION_PRIVATE_KEY=
EVM_PRIVATE_KEY=
GNO_PRIVATE_KEY=

# Sanitized output. The state file is used by --resume and must remain mode 0600.
E2E_ARTIFACT_DIR=./channel-e2e-artifacts
E2E_STATE_FILE=./channel-e2e-artifacts/state.json
