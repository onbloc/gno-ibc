func TestMembershipProofPath(t *testing.T) {
	tests := []struct {
		name        string
		clientId    ClientId
		proofHeight uint64
		path        []byte
		want        string
	}{
		{
			name:        "all zeros",
			clientId:    0,
			proofHeight: 0,
			path:        []byte{},
			want:        "f176875aca8f4f3c6807a2a152c99d4c8234c0eff703dbd4df11772a47e5c84c",
		},
		{
			name:        "with values",
			clientId:    1,
			proofHeight: 100,
			path:        []byte{0x01, 0x02, 0x03},
			want:        "802b51c2db1c2d8cac99d3d84d3410f9f41d5319f32984db7e74c008a8cc9731",
		},
		{
			name:        "large values",
			clientId:    10000,
			proofHeight: 1000000,
			path:        bytes.Repeat([]byte{0xaa}, 32),
			want:        "e5540aca01035d48b5e7dcbe249627d0afb9713efb664e35ba366d5a9e9a4af8",
		},
		{
			name:        "max uint64 height",
			clientId:    5,
			proofHeight: 0xFFFFFFFFFFFFFFFF,
			path:        []byte{0xff, 0xee, 0xdd},
			want:        "7bfc7038cb44538946f391d96b0deee4906cc16b65033ab64c4e813dccd8c35b",
		},
	}

	for _, tc := range tests {
		t.Run(tc.name, func(t *testing.T) {
			got := MembershipProofPath(tc.clientId, tc.proofHeight, tc.path)
			assertHex(t, tc.name, got[:], tc.want)
		})
	}
}

func TestNonMembershipProofPath(t *testing.T) {
	tests := []struct {
		name        string
		clientId    ClientId
		proofHeight uint64
		path        []byte
		want        string
	}{
		{
			name:        "all zeros",
			clientId:    0,
			proofHeight: 0,
			path:        []byte{},
			want:        "e84ec332e3c2809f3fac920f7ba64b5510abb058ab01ec4418ccc94549cf47a1",
		},
		{
			name:        "with values",
			clientId:    1,
			proofHeight: 100,
			path:        []byte{0x01, 0x02, 0x03},
			want:        "22e093a4df346cfd573c880ea4198841e0bc3dfce34accd632f2add9c0a79b06",
		},
		{
			name:        "large values",
			clientId:    10000,
			proofHeight: 1000000,
			path:        bytes.Repeat([]byte{0xbb}, 32),
			want:        "1558e9d519d6fc58198d3d3d76a1168b2c5d6d7f2d734c7a4b4f00ddc656459a",
		},
		{
			name:        "max uint64 height",
			clientId:    5,
			proofHeight: 0xFFFFFFFFFFFFFFFF,
			path:        []byte{0x11, 0x22, 0x33},
			want:        "062516bfa4d3caebc29879a0f9c4998b8111cad47c809ed971e0cde7620d0094",
		},
	}

	for _, tc := range tests {
		t.Run(tc.name, func(t *testing.T) {
			got := NonMembershipProofPath(tc.clientId, tc.proofHeight, tc.path)
			assertHex(t, tc.name, got[:], tc.want)
		})
	}
}

func TestPacketCommitmentPath(t *testing.T) {
	tests := []struct {
		name    string
		packet  Packet
		want    string
		wantErr bool
	}{
		{
			name: "basic packet",
			packet: Packet{
				SourceChannelId:      1,
				DestinationChannelId: 2,
				Data:                 []byte{0xab, 0xcd},
				TimeoutHeight:        0,
				TimeoutTimestamp:     3,
			},
			want:    "dfac6be4ea8189f2107780fd50b6532901f7692506a56c45e224a15d64eb040c",
			wantErr: false,
		},
		{
			name: "packet with empty data",
			packet: Packet{
				SourceChannelId:      0,
				DestinationChannelId: 1,
				Data:                 []byte{},
				TimeoutHeight:        0,
				TimeoutTimestamp:     100,
			},
			want:    "d56102fe70b54c587934a3e35d3c40b458da7fb1fd48ef655b38e1ec99fda460",
			wantErr: false,
		},
		{
			name: "packet with large data",
			packet: Packet{
				SourceChannelId:      100,
				DestinationChannelId: 200,
				Data:                 bytes.Repeat([]byte{0xff}, 64),
				TimeoutHeight:        0,
				TimeoutTimestamp:     10000,
			},
			want:    "f9598f0d8f8ff023f550e12f8d1d7fdb6617a3db6dfcdc75e0ae94c29089618b",
			wantErr: false,
		},
		{
			name: "packet with nil data and max timestamp",
			packet: Packet{
				SourceChannelId:      0xFFFFFFFF,
				DestinationChannelId: 0xFFFFFFFE,
				Data:                 nil,
				TimeoutHeight:        0,
				TimeoutTimestamp:     0xFFFFFFFFFFFFFFFF,
			},
			want:    "73bf318b8cceb6bd6ee3d6acaa3819fddb30018b42cb57bc55562cdd2e759800",
			wantErr: false,
		},
	}

	for _, tc := range tests {
		t.Run(tc.name, func(t *testing.T) {
			got, err := PacketCommitmentPath(tc.packet)
			if tc.wantErr {
				if err == nil {
					t.Fatal("expected error, got nil")
				}
				return
			}
			if err != nil {
				t.Fatalf("unexpected error: %v", err)
			}
			assertHex(t, tc.name, got[:], tc.want)
		})
	}
}

func TestPacketAcknowledgementPath(t *testing.T) {
	tests := []struct {
		name    string
		packet  Packet
		want    string
		wantErr bool
	}{
		{
			name: "basic packet",
			packet: Packet{
				SourceChannelId:      1,
				DestinationChannelId: 2,
				Data:                 []byte{0xab, 0xcd},
				TimeoutHeight:        0,
				TimeoutTimestamp:     3,
			},
			want:    "af591cb9e48aa20a528e75d0a6eea3caa16e49e3fef9e16781e5284f659ddf80",
			wantErr: false,
		},
		{
			name: "packet with empty data",
			packet: Packet{
				SourceChannelId:      0,
				DestinationChannelId: 1,
				Data:                 []byte{},
				TimeoutHeight:        0,
				TimeoutTimestamp:     100,
			},
			want:    "74dd41d176f27cca1cbd07107e2042d3f3b2e91076ae2e66afa382c39ce80f0a",
			wantErr: false,
		},
		{
			name: "packet with large data",
			packet: Packet{
				SourceChannelId:      50,
				DestinationChannelId: 150,
				Data:                 bytes.Repeat([]byte{0xaa}, 128),
				TimeoutHeight:        0,
				TimeoutTimestamp:     5000,
			},
			want:    "f6b0ac3c8204dad4893813d7266cc882d56ac6d7b00e88390139122fe31b8dee",
			wantErr: false,
		},
		{
			name: "packet with nil data and zero values",
			packet: Packet{
				SourceChannelId:      0,
				DestinationChannelId: 0,
				Data:                 nil,
				TimeoutHeight:        0,
				TimeoutTimestamp:     0,
			},
			want:    "f43dc2390ae6b256dada11475f81acd313280a4071f344ea59b2a9090a8e3c50",
			wantErr: false,
		},
	}

	for _, tc := range tests {
		t.Run(tc.name, func(t *testing.T) {
			got, err := PacketAcknowledgementPath(tc.packet)
			if tc.wantErr {
				if err == nil {
					t.Fatal("expected error, got nil")
				}
				return
			}
			if err != nil {
				t.Fatalf("unexpected error: %v", err)
			}
			assertHex(t, tc.name, got[:], tc.want)
		})
	}
}
