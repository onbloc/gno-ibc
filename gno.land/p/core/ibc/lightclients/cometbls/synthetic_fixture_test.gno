			name:    "z36_ack_membership",
			key:     mustHex("01a2eb330b6260811ce5ca10fbff1cfb4611444cc65003ad76eacd804085ce55"),
			value:   mustHex("51b1bc1398f211274f5339ff648616f0aaf364c1cab142847beae15e25a0f2d9"),
			rootHex: "6bc60fa26180e35fbd00483796a45484c79b23f5b5eb84c516a499f317fcbfea",
			proofHex: "0add010ada010a2001a2eb330b6260811ce5ca10fbff1cfb4611444cc65003ad76eacd804085ce55" +
				"122051b1bc1398f211274f5339ff648616f0aaf364c1cab142847beae15e25a0f2d91a0d0801" +
				"1000180120012a03000202222b08011204020402201a21208cb10ed5327260edb18c98511ad911" +
				"082d8a530ba825451f7d79389195ecf968222b08011204040802201a21208ac78e8b801078cf" +
				"45ca9b0083fc4c2757aef29252e601f90431b4df4bd5a036222b08011204060a02201a21201c" +
				"088875fa1d312c11a5906d629222fb38eb4d95c71a0c2c7899672746f529150a360a340a036962" +
				"631220ac88736e58895d9f1e865f0a2c44819fcdc704c9cb302f17305a98603d445fd01a0b0801" +
				"1000180120012a0100",
		},
	}

	for _, tc := range cases {
		proofs, err := DecodeProofs(mustHex(tc.proofHex))
		if err != nil {
			t.Fatalf("%s DecodeProofs: %v", tc.name, err)
		}

		cs := baseCS()
		client := newTestClient(cs, map[Height]ConsensusState{
			cs.LatestHeight: {
				Timestamp: testNow,
				Root:      MerkleRoot{Hash: mustHex(tc.rootHex)},
			},
		})
		path := types.MerklePath{KeyPath: [][]byte{[]byte("ibc"), tc.key}}
		if err := client.VerifyMembership(cs.LatestHeight, proofs, path, tc.value); err != nil {
			t.Fatalf("%s VerifyMembership: %v", tc.name, err)
		}
	}
}

func TestSyntheticNonMembershipProofFixture(t *testing.T) {
	cases := []struct {
		name     string
		key      []byte
		rootHex  string
		proofHex string
	}{
		{
			name:    "packet",
			key:     []byte("packet-key-missing"),
			rootHex: "4d52c3c46fce6c9d7cd187c0cbf6a7dd6e8f0d89661d98b5b9e2161d8a965323",
			proofHex: "0a6c126a0a127061636b65742d6b65792d6d697373696e6712540a0a7061636b65742d6b657912" +
				"0c7061636b65742d76616c75651a0d08011000180120012a0300020222290801122504060220d1" +
				"e824347279953135d11eb8eca353e5e22dcf0b08b408dc170c133c0fc00f49200a360a340a03" +
				"6962631220755595e19553fed6b6654dc0ea6c44fae960c5c242cba6b336412fb2b45a02eb1a" +
				"0b08011000180120012a0100",
		},
		{
			name:    "z37_receipt",
			key:     mustHex("aaa7bd6e1524998c867fc9248d3940e6873a82884f0754f79fd7bec370f222b7"),
			rootHex: "6bc60fa26180e35fbd00483796a45484c79b23f5b5eb84c516a499f317fcbfea",
			proofHex: "0aa50112a2010a20aaa7bd6e1524998c867fc9248d3940e6873a82884f0754f79fd7bec370f222" +
				"b7127e0a2088601476d11616a71c5be67555bd1dff4b1cbf21533d2669b768b61518cfe1c31220" +
				"fa3c11d224a164cd0beca2b6756128dc1531714a75813e9c2b5840bd8f2a83471a0d0801100018" +
				"0120012a03000202222908011225060a02207d3f120234fb6594632763f957f246d75fe4d3185e" +
				"018859453279684f04f3d1200a360a340a036962631220ac88736e58895d9f1e865f0a2c44819" +
				"fcdc704c9cb302f17305a98603d445fd01a0b08011000180120012a0100",
		},
	}

	for _, tc := range cases {
		proofs, err := DecodeProofs(mustHex(tc.proofHex))
		if err != nil {
			t.Fatalf("%s DecodeProofs: %v", tc.name, err)
		}

		cs := baseCS()
		client := newTestClient(cs, map[Height]ConsensusState{
			cs.LatestHeight: {
				Timestamp: testNow,
				Root:      MerkleRoot{Hash: mustHex(tc.rootHex)},
			},
		})
		path := types.MerklePath{KeyPath: [][]byte{[]byte("ibc"), tc.key}}
		if err := client.VerifyNonMembership(cs.LatestHeight, proofs, path); err != nil {
			t.Fatalf("%s VerifyNonMembership: %v", tc.name, err)
		}
	}
}
