package main

import (
	"crypto/keccak256"
	"encoding/hex"

	z "gno.land/p/gnoswap/ibc/zkgm"
	core "gno.land/r/core/ibc/v1/core"
	e2e "gno.land/r/gnoswap/ibc/v1/apps/zkgm/testing/e2e"
)

const mockReceiverPath = "gno.land/r/gnoswap/ibc/v1/apps/zkgm/testing/mock"
const missingReceiverPath = "gno.land/r/gnoswap/ibc/v1/apps/zkgm/testing/missing"

func main() {
	packet := z39CallPacket(mockReceiverPath)
	packetKey := packetCommitmentPath(packet)
	packetValue := core.COMMITMENT_MAGIC
	missingPacket := z39CallPacket(missingReceiverPath)
	missingPacketKey := packetCommitmentPath(missingPacket)

	printKV("call_packet_commitment", packetKey[:], packetValue[:])
	println("packet_data", "0x"+hex.EncodeToString(packet.Data))
	printKV("missing_call_packet_commitment", missingPacketKey[:], packetValue[:])
	println("missing_packet_data", "0x"+hex.EncodeToString(missingPacket.Data))
}

func z39CallPacket(receiverPath string) core.Packet {
	call := z.Call{
		Sender:           []byte("sender"),
		ContractAddress:  []byte(receiverPath),
		ContractCalldata: []byte("calldata"),
	}
	return core.NewPacket(
		cross,
		core.Sequence(9),
		core.ChannelId(2),
		core.ChannelId(1),
		e2e.MustPacketData(cross, e2e.MustCallInstruction(cross, call)),
		core.Timestamp(0),
	)
}

func hash(bz []byte) [32]byte {
	return keccak256.Sum256(bz)
}

func packetCommitmentPath(packet core.Packet) [32]byte {
	batchHash := hash(packet.EthAbiEncode())
	return hash(concat(core.PACKETS[:], batchHash[:]))
}

func concat(parts ...[]byte) []byte {
	size := 0
	for _, p := range parts {
		size += len(p)
	}
	out := make([]byte, 0, size)
	for _, p := range parts {
		out = append(out, p...)
	}
	return out
}

func printKV(name string, key []byte, value []byte) {
	println(name+"_key", "0x"+hex.EncodeToString(key))
	println(name+"_value", "0x"+hex.EncodeToString(value))
}

