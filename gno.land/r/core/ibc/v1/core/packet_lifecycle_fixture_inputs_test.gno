package core

import "testing"

func TestPacketLifecycleFixtureInputPaths(t *testing.T) {
	packet := Packet{
		Sequence:             0,
		SourceChannelId:      1,
		DestinationChannelId: 2,
		Data:                 Bytes(mustHex("")),
		TimeoutTimestamp:     3600,
	}
	ack := Bytes(mustHex(""))

	assertH256Hex(t, "z36 ack membership key", PacketAcknowledgementPath(packet), "0x7cdf87cee2bf28fffdd8dd98af1ed5bd99585afb5b6e537d718f1f9391b44067")
	assertH256Hex(t, "z36 ack membership value", keccak(ack), "0x41502841361a25f62632a8138da2f5da1948539832b0fc2bfb733cc7b081836e")
	assertH256Hex(t, "z37 receipt non-membership key", PacketReceiptPath(packet), "0xaaa7bd6e1524998c867fc9248d3940e6873a82884f0754f79fd7bec370f222b7")
}
