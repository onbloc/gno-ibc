package core

import "testing"

func TestPacketLifecycleFixtureInputPaths(t *testing.T) {
	packet := Packet{
		SourceChannelId:      1,
		DestinationChannelId: 2,
		Data:                 Bytes(mustHex("")),
		TimeoutTimestamp:     3600,
	}
	ack := mustHex("")

	assertH256Hex(t, "z36 ack membership key", PacketAcknowledgementPath(packet), "0x3cde3b6891df12ae3a04f23e62738b1c7e209ddb5a5dd6ebc27b6c29cd539b18")
	assertH256Hex(t, "z36 ack membership value", CommitAcks([][]byte{ack}), "0x015b3cd48177600c2efac9e26b978edfdf97f8480c0a7f3b0884f0b4817ed5a8")
	assertH256Hex(t, "z37 receipt non-membership key", PacketAcknowledgementPath(packet), "0x3cde3b6891df12ae3a04f23e62738b1c7e209ddb5a5dd6ebc27b6c29cd539b18")
}
