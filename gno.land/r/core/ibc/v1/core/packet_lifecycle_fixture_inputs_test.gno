package core

import "testing"

func TestPacketLifecycleFixtureInputPaths(t *testing.T) {
	packet := Packet{
		Sequence:             0,
		SourceChannelId:      1,
		DestinationChannelId: 2,
		Data:                 Bytes(mustHex("")),
		TimeoutTimestamp:     3600,
	}
	ack := Bytes(mustHex(""))

	assertH256Hex(t, "z36 ack membership key", PacketAcknowledgementPath(packet), "0x01a2eb330b6260811ce5ca10fbff1cfb4611444cc65003ad76eacd804085ce55")
	assertH256Hex(t, "z36 ack membership value", keccak(ack), "0x51b1bc1398f211274f5339ff648616f0aaf364c1cab142847beae15e25a0f2d9")
	assertH256Hex(t, "z37 receipt non-membership key", PacketReceiptPath(packet), "0xaaa7bd6e1524998c867fc9248d3940e6873a82884f0754f79fd7bec370f222b7")
}
